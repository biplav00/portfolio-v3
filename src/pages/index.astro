---
import About from '../components/common/About.astro';
import ContactSidebar from '../components/common/ContactSidebar.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const siteUrl = 'https://biplavsubedi.com.np';
const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      name: 'Biplav Subedi',
      alternateName: ['Biplav Subedi QA Engineer', 'biplav00'],
      url: siteUrl,
    },
    {
      '@type': 'ProfilePage',
      mainEntity: {
        '@type': 'Person',
        '@id': `${siteUrl}/#person`,
        name: 'Biplav Subedi',
        givenName: 'Biplav',
        familyName: 'Subedi',
        url: siteUrl,
        jobTitle: 'QA Engineer',
        description:
          'QA Engineer focused on test automation, CI/CD integration, and building reliable software. Currently at Yirifi.ai.',
        email: 'biplavsubedi0@gmail.com',
        image: `${siteUrl}/og-image.png`,
        address: {
          '@type': 'PostalAddress',
          addressLocality: 'Kathmandu',
          addressCountry: 'NP',
        },
        knowsAbout: [
          'Test Automation',
          'Playwright',
          'Selenium',
          'CI/CD',
          'API Testing',
          'Python',
          'TypeScript',
        ],
        worksFor: {
          '@type': 'Organization',
          name: 'Yirifi.ai',
        },
        alumniOf: {
          '@type': 'Organization',
          name: 'Karobar Pvt. Ltd.',
        },
        sameAs: [
          'https://github.com/biplav00',
          'https://linkedin.com/in/biplav00',
          'https://x.com/biplav00',
        ],
      },
    },
  ],
});
---

<BaseLayout title="Biplav Subedi — QA Engineer | Test Automation, CI/CD, Playwright" description="Biplav Subedi is a QA Engineer from Kathmandu, Nepal focused on test automation, CI/CD integration, and building reliable software. Currently at Yirifi.ai.">
  <script slot="head" type="application/ld+json" set:html={jsonLd} />
  <About />
  <ContactSidebar />
</BaseLayout>
